# ─── Required ───
# No API keys required for the converter itself.
# The app works without Stripe — payment gating is optional.

# Site URL (used for metadata, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://asycuda-converter-2.vercel.app

# ─── Payment (Optional — Stripe) ───
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_PRICE_ID=price_xxx

# ─── Support Email (Optional) ───
# SUPPORT_EMAIL=support@asycuda-converter.com

# ─── Rate Limiting (Optional — Upstash Redis) ───
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
